NEXT_PUBLIC_REWARD_TOKEN=USDC
NEXT_PUBLIC_CYCLE_SECONDS=60
NEXT_PUBLIC_MIN_HOLDING=10000
NEXT_PUBLIC_BUY_URL=https://jup.ag/swap/SOL-YOUR_MINT
NEXT_PUBLIC_CHART_URL=https://dexscreener.com/solana/YOUR_MINT
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_TELEGRAM_URL=
