# Frontend environment variables (set in Vercel or .env.local)
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
NEXT_PUBLIC_TOKEN_NAME=MyToken
NEXT_PUBLIC_TOKEN_SYMBOL=$MTK
NEXT_PUBLIC_TOKEN_DESCRIPTION=Auto-distributes rewards to all holders
